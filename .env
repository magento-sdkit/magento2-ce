MAIN_DOMAIN=mage.test
MULTIPLE_DOMAINS=abc.mage.test
PHP_VER=7.4
ENABLE_SENDMAIL=true
DEBUG=false
WITH_XDEBUG=1
MAGENTO_RUN_MODE=developer
DOCKER_VER_TAG=-1.2.2
MAGENTO_ROOT=/app
DOCUMENT_ROOT=/pub
SOURCE_PATH=./
RUNNING_DIR=/var/www/docker
VARNISH_CONFIG_DIR=/var/www/docker
UPLOAD_MAX_FILESIZE=128M
PHP_MEMORY_LIMIT=2G
COMPOSER_VERSION=2.0.12
SHARED_SERVICES=mysql redis elasticsearch
EXT_PHP_EXTENSIONS=sodium
HOST_IP=172.17.0.1
